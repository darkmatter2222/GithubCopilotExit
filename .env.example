# GithubCopilotExit — environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and must NEVER be committed.

# Remote server — RTX 3090 LLM host
SSH_USER=your_linux_username
SSH_HOST=192.168.x.x          # LAN IP of your GPU server
SSH_KEY_PATH=~/.ssh/id_rsa
REMOTE_PATH=/home/your_linux_username/llm-stack

# Proxy API
API_PORT=8001

# Model
OLLAMA_MODEL=qwen3.6:27b-mtp-q4_K_M
SERVED_MODEL_NAME=qwen3
MIN_TEMPERATURE=0.6
