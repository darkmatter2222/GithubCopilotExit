# LLM Proxy Configuration
# Copy to .env and fill in your values. Never commit .env to git.

# Ollama (primary backend - always on)
# On DGX Spark: Ollama runs as a systemd service on the host, not in Docker.
# Use the host IP or host.docker.internal from inside a container.
OLLAMA_BASE_URL=http://localhost:11434

# vLLM (optional secondary backend)
# Comma-separated if you run multiple vLLM instances on different ports.
# Leave blank if you are Ollama-only.
# VLLM_BASE_URL=http://localhost:8000

# Inference behavior
# Minimum temperature for Qwen3 thinking-mode compatibility.
# VS Code Copilot sends 0.1 by default; Qwen3 thinking requires >= 0.6.
MIN_TEMPERATURE=0.6

# Suppress thinking chains by default (inject reasoning_effort=none).
# Clients can override by sending reasoning_effort=auto/high/low explicitly.
DISABLE_THINKING_FOR_TOOLS=true

# How often (seconds) the proxy re-queries backends for new/removed models.
ROUTER_REFRESH_S=30

# MongoDB persistence (optional)
# Leave MONGO_URI blank to run in memory-only mode (history/usage tabs N/A).
MONGO_URI=mongodb://ryan:yourpassword@192.168.86.48:27017/radiacode?authSource=radiacode
MONGO_DB=radiacode

# Proxy port (used by start-proxy-local.ps1; Docker always exposes 8001)
API_PORT=8001

# ─── Dashboard Configuration ──────────────────────────────────────────
# Remote Dashboard Deployment — allows the dashboard container to run on a
# different server than the proxy + Ollama (e.g., dashboard on "databrick",
# proxy + Ollama on DGX Spark).
#
# PROXY_BACKEND — upstream URL for server-side API proxying. Set this when
#   deploying behind nginx ingress so serve.py forwards /stats, /v1/models,
#   /api/... requests to the actual DGX Spark proxy:
#     PROXY_BACKEND=http://dgxspark:8001
#     PROXY_BACKEND=http://192.168.86.39:8001
#   Leave blank (default) when dashboard and proxy share the same host.
#   Legacy alias: PROXY_URL or DASHBOARD_PROXY_URL also work.
#
# HTML always injects empty PROXY_URL into the browser so all pFetch() calls
# use relative paths (/stats, /v1/models, etc.) which hit serve.py and get
# proxied server-side to PROXY_BACKEND. No CORS issues.
#
PROXY_BACKEND=http://dgxspark:8001

# The standalone dashboard container serves on this port (Docker internal):
# When behind nginx ingress, the upstream must use port 3000 (internal),
# NOT the host-mapped port (e.g., 3002). Port mappings are stripped inside
# Docker networks.
DASHBOARD_PORT=3000
