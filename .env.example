# LLM Proxy Configuration
# Copy to .env and fill in your values. Never commit .env to git.

# Ollama (primary backend - always on)
# On DGX Spark: Ollama runs as a systemd service on the host, not in Docker.
# Use the host IP or host.docker.internal from inside a container.
OLLAMA_BASE_URL=http://localhost:11434

# vLLM (optional secondary backend)
# Comma-separated if you run multiple vLLM instances on different ports.
# Leave blank if you are Ollama-only.
# VLLM_BASE_URL=http://localhost:8000

# Inference behavior
MIN_TEMPERATURE=0.6
DISABLE_THINKING_FOR_TOOLS=true
ROUTER_REFRESH_S=30

# MongoDB persistence (optional)
MONGO_URI=mongodb://ryan:yourpassword@192.168.86.48:27017/radiacode?authSource=radiacode
MONGO_DB=radiacode
API_PORT=8001

# Security / Authentication
# API_KEY_REQUIRED=true enables Bearer token enforcement on all /v1/* and /api/* endpoints.
# Generate a key: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY_REQUIRED=true
PROXY_API_KEYS=your-static-api-key-here
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-admin-password

# Dashboard login credentials (serve.py)
DASHBOARD_USERNAME=your-dashboard-username
DASHBOARD_PASSWORD=your-dashboard-password
PROXY_API_KEY=your-static-api-key-here

# Remote Dashboard Deployment
PROXY_BACKEND=http://dgxspark:8001
DASHBOARD_PORT=3000
