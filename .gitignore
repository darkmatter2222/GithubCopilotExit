# GithubCopilotExit — .gitignore

# Secrets — never commit
.env
.env.*
!.env.example

# Ollama model files (large binary blobs — don't commit these)
*.gguf
*.bin
Modelfile.*
!templates/

# OS
.DS_Store
Thumbs.db
desktop.ini

# PowerShell
*.ps1xml

# Temp / logs
*.log
*.tmp

# Python compiled / cache
__pycache__/
*.pyc
*.pyo
.venv/
