# GithubCopilotExit — .gitignore

# Secrets — never commit
.env
.env.*
!.env.example

# Personal launcher bat — contains API keys and passwords; copy from copilot-dgx.bat.example
copilot-dgx.bat

# Deployment scripts with credentials
scripts/deploy-dgxspark.py
scripts/final-deploy.py
scripts/install-docker-*.py
scripts/install-docker-*.sh

# Allow the main deploy script (reads from .env, no hardcoded secrets)
!scripts/deploy.py

# Ollama model files (large binary blobs)
*.gguf
*.bin
Modelfile.*
!templates/

# OS
.DS_Store
Thumbs.db
desktop.ini

# PowerShell
*.ps1xml

# Temp / logs
*.log
*.tmp
[Ll]ogs/

# Python compiled / cache
__pycache__/
*.pyc
*.pyo
.venv/
[Dd]ocs/

# Build metadata generated by scripts/deploy.py (proxy/dashboard version stamping)
.version